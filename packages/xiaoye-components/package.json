{
  "name": "xiaoye-components",
  "version": "0.2.0",
  "type": "module",
  "description": "通用 Vue 3 基础组件库",
  "license": "MIT",
  "homepage": "https://github.com/zhangzhengyang27/xiaoye-components#readme",
  "bugs": {
    "url": "https://github.com/zhangzhengyang27/xiaoye-components/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangzhengyang27/xiaoye-components.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "design-system",
    "ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/index.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.6.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@floating-ui/dom": "^1.6.13",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "async-validator": "^4.2.5",
    "dayjs": "^1.11.20",
    "rrule": "^2.8.1"
  }
}
