{
  "name": "xiaoye-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "前台产品 Vue 3 组件库",
  "license": "MIT",
  "homepage": "https://github.com/zhangzhengyang27/xiaoye-components#readme",
  "bugs": {
    "url": "https://github.com/zhangzhengyang27/xiaoye-components/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangzhengyang27/xiaoye-components.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "design-system",
    "ui",
    "front-end"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": {
      "types": "./style.css.d.ts",
      "default": "./style.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "vue": "^3.5.0",
    "xiaoye-primitives": "workspace:*",
    "xiaoye-components": "workspace:*"
  }
}
