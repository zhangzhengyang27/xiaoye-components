{
  "name": "xiaoye-primitives",
  "version": "1.0.0",
  "type": "module",
  "description": "xiaoye 组件库基础设施：composables + utils + theme",
  "license": "MIT",
  "homepage": "https://github.com/zhangzhengyang27/xiaoye-components#readme",
  "bugs": {
    "url": "https://github.com/zhangzhengyang27/xiaoye-components/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangzhengyang27/xiaoye-components.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "utils",
    "design-system",
    "ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
